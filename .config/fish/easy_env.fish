fish_vi_key_bindings

#environment variables
set -gx APP_IMAGE_PATH ~/Desktop/app_images
set -gx SOURCE_CODES ~/Desktop/source_codes_for_building
set -gx EDITOR nvim
set -gx JAVA_HOME ~/java/bin
set -gx MANPAGER "nvim +Man!"
